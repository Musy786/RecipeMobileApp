<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RecipeApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:RecipeApp.Pages"
    Shell.FlyoutBehavior="Flyout"
    Title="RecipeApp">

    <ShellContent Title="Home" ContentTemplate="{DataTemplate pages:MainPage}"/>
    <ShellContent Route="Recipes" ContentTemplate="{DataTemplate pages:RecipesPage}"/>
    <ShellContent Route="AddRecipe" ContentTemplate="{DataTemplate pages:AddRecipePage}"/>

</Shell>