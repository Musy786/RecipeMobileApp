
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RecipeApp.Pages.RecipesPage">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            
            <Label Text="Your Recipes"
                   FontSize="28"
                   HorizontalOptions="Center" />
            
            <!--For when there are no recipes saved yet-->
            <Label x:Name="emptyLabel"
                   Text="No recipes yet..."
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="Gray"
                   IsVisible="False" />
            
            <CollectionView x:Name="recipesList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="10" Padding="10" BorderColor="Gray" CornerRadius="10">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18" />
                                <Label Text="{Binding Description}" FontSize="14" TextColor="Gray" />
                                <Label Text="Ingredients:" FontAttributes="Bold" />                                <!--Like a subheading (e.g. "Ingredients:")-->
                                <Label Text="{Binding Ingredients}" FontSize="13" />                      <!--The aforementioned ingredients-->
                                <Label Text="Steps:" FontAttributes="Bold" />
                                <Label Text="{Binding Steps}" FontSize="13" />
                                <HorizontalStackLayout Spacing="15">
                                    <Label Text="{Binding PrepTime, StringFormat='Prep: {0} min'}" />
                                    <Label Text="{Binding CookTime, StringFormat='Cook: {0} min'}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            
            <Button 
                Text="Clear All Recipes"
                TextColor="White"
                BackgroundColor="DarkRed"
                Margin="8"
                Clicked="OnClearRecipesClicked"/>
            
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>