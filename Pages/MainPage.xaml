<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeApp.Pages.MainPage"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Welcome to RecipeApp!"
                   FontSize="28"
                   HorizontalOptions="Center" />

            <Label Text="Start creating or browsing your favourite recipes."
                   FontSize="18"
                   HorizontalOptions="Center" />

            <Button Text="View All Recipes"
                    Clicked="OnViewAllRecipesClicked" />

            <Button Text="Add New Recipe" 
                    Clicked="OnAddNewRecipeClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>