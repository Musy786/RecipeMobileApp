
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RecipeApp.Pages.RecipesPage">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20">
        
        <Label Text="Your Recipes"
               FontSize="28"
               HorizontalOptions="Center"
               Grid.Row="0"
               Margin="0,0,0,5" />
        
        <!--Search bar for filtering recipes by name-->
        <SearchBar Placeholder="Search recipes..."
                   Text="{Binding SearchText, Mode=TwoWay}"
                   Grid.Row="1"
                   Margin="0,0,0,10" />
        
        <CollectionView ItemsSource="{Binding Recipes}" Grid.Row="2"
                        SelectionMode="None">
            
            <!--For when there are no recipes added yet-->
            <CollectionView.EmptyView>
                <Label Text="No recipes yet..."
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="Gray" />
            </CollectionView.EmptyView>
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.LeftItems>
                            <SwipeItems>
                                <SwipeItem Text="Edit"
                                           BackgroundColor="DarkOrange"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditRecipeCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.LeftItems>
                        
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="DarkRed"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteRecipeCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        
                        <Frame Margin="0,5" Padding="10" BorderColor="Gray" CornerRadius="10">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18" />
                                <Label Text="{Binding Description}" FontSize="14" TextColor="Gray" />
                                <Label Text="Ingredients:" FontAttributes="Bold" />                                    
                                <Label Text="{Binding Ingredients}" FontSize="13" />                      
                                <Label Text="Steps:" FontAttributes="Bold" />
                                <Label Text="{Binding Steps}" FontSize="13" />
                                <HorizontalStackLayout Spacing="15">
                                    <Label Text="{Binding PrepTime, StringFormat='Prep: {0} min'}" />
                                    <Label Text="{Binding CookTime, StringFormat='Cook: {0} min'}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Button 
            Text="Clear All Recipes"
            TextColor="White"
            BackgroundColor="DarkRed"
            Margin="8"
            Grid.Row="3"
            Command="{Binding ClearAllRecipesCommand}"/>
    </Grid>
    
</ContentPage>
