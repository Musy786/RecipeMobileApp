
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RecipeApp.Pages.RecipesPage"
    Title="Your Recipes">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20">
        
        <Label Text="Your Recipes"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Grid.Row="0"
               Margin="0,0,0,5" />
        
        <!--Search bar for filtering recipes by name, description, or ingredients-->
        <SearchBar Placeholder="Search recipes..."
                   Text="{Binding SearchText, Mode=TwoWay}"
                   Grid.Row="1"
                   Margin="0,0,0,10" />
        
        <CollectionView ItemsSource="{Binding Recipes}" Grid.Row="2"
                            SelectionMode="None">
            
            <!--For when there are no recipes added yet-->
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="No recipes yet..."
                           FontSize="18"
                           HorizontalOptions="Center"
                           TextColor="Gray" />
                    <Label Text="Add your first recipe to get started!"
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.LeftItems>
                            <SwipeItems>
                                <SwipeItem Text="Edit"
                                           BackgroundColor="DarkOrange"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditRecipeCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.LeftItems>
                        
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="DarkRed"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteRecipeCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        
                        <Border Stroke="{StaticResource Gray200}" 
                                StrokeShape="RoundRectangle 12" 
                                Padding="14" 
                                Margin="0,5"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditRecipeCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="6">
                                <!--Recipe name and time summary on the same row-->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18" Grid.Column="0" />
                                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                        <Label Text="{Binding PrepTime, StringFormat='Prep: {0}m'}" FontSize="12" TextColor="Gray" />
                                        <Label Text="{Binding CookTime, StringFormat='Cook: {0}m'}" FontSize="12" TextColor="Gray" />
                                    </HorizontalStackLayout>
                                </Grid>
                                
                                <Label Text="{Binding Description}" FontSize="14" TextColor="Gray" />
                                
                                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4" />
                                
                                <Label Text="Ingredients" FontAttributes="Bold" FontSize="13" />
                                <Label Text="{Binding Ingredients}" FontSize="13" TextColor="{StaticResource Gray500}" />
                                
                                <Label Text="Steps" FontAttributes="Bold" FontSize="13" />
                                <Label Text="{Binding Steps}" FontSize="13" TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Button 
            Text="Clear All Recipes"
            TextColor="White"
            BackgroundColor="DarkRed"
            CornerRadius="8"
            Margin="0,8"
            Grid.Row="3"
            Command="{Binding ClearAllRecipesCommand}"/>
    </Grid>
    
</ContentPage>