
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RecipeApp.Pages.AddRecipePage">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Add your Recipes here" FontSize="28" HorizontalOptions="Center" />
            
            <Entry x:Name="recipeName" Placeholder="Recipe Name" />

            <Entry x:Name="description" Placeholder="Description" MaxLength="200" />

            <Entry x:Name="ingredients" Placeholder="Ingredients (comma separated)" />

            <Entry x:Name="steps" Placeholder="Steps (summary)" Keyboard="Default" />

            <HorizontalStackLayout Spacing="10">
                <Entry x:Name="prepTime" 
                       Placeholder="Prep Time (mins)"
                       Keyboard="Numeric"
                       WidthRequest="125" />
                <Entry x:Name="cookTime"
                       Placeholder="Cook Time (mins)"
                       Keyboard="Numeric"
                       WidthRequest="125" />
            </HorizontalStackLayout>

            <Button Text="Save Recipe" Clicked="OnSaveRecipeClicked" />
            
        </VerticalStackLayout>
    </ScrollView>
            
</ContentPage>