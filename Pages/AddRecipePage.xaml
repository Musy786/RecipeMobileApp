
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RecipeApp.Pages.AddRecipePage"
    Title="Add Recipe">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Add a New Recipe" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,10" />
            
            <Label Text="Recipe Name" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
            <Entry x:Name="recipeNameEntry" Text="{Binding RecipeName, Mode=TwoWay}" 
                   Placeholder="e.g. Spaghetti Bolognese" MaxLength="100" />

            <Label Text="Description" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
            <Entry x:Name="descriptionEntry" Text="{Binding Description, Mode=TwoWay}" 
                   Placeholder="A short description of the dish" MaxLength="200" />

            <Label Text="Ingredients" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
            <Entry x:Name="ingredientsEntry" Text="{Binding Ingredients, Mode=TwoWay}" 
                   Placeholder="Comma separated (e.g. pasta, mince, tomato)" />

            <Label Text="Steps" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
            <Entry x:Name="stepsEntry" Text="{Binding Steps, Mode=TwoWay}" 
                   Placeholder="Brief step summary" Keyboard="Default" />

            <Label Text="Time (minutes)" FontSize="13" FontAttributes="Bold" TextColor="Gray" />
            <HorizontalStackLayout Spacing="10">
                <Entry x:Name="prepTimeEntry" Text="{Binding PrepTime, Mode=TwoWay}" 
                       Placeholder="Prep Time (mins)"
                       Keyboard="Numeric"
                       WidthRequest="125" />
                <Entry x:Name="cookTimeEntry" Text="{Binding CookTime, Mode=TwoWay}"
                       Placeholder="Cook Time (mins)"
                       Keyboard="Numeric"
                       WidthRequest="125" />
            </HorizontalStackLayout>

            <Button Text="Save Recipe" 
                    Command="{Binding SaveRecipeCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="8"
                    FontSize="16"
                    Margin="0,10,0,0" />
            
        </VerticalStackLayout>
    </ScrollView>
            
</ContentPage>